# Copy to .env and adjust values
# Use same username/password as pgAdmin → Server → Properties → Connection
DB_USER=postgres
DB_PASSWORD=your_pgadmin_password
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=geo_test_hub
SECRET_KEY=change-this-to-a-random-secret-in-production
LOG_LEVEL=INFO
FLASK_DEBUG=1

# React dev server (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
