# Use port 5433 when connecting to Docker Postgres from the host (mapped in docker-compose)
DATABASE_URL=postgresql+asyncpg://gvip:gvip_secret@localhost:5433/gvip
DATABASE_URL_SYNC=postgresql://gvip:gvip_secret@localhost:5433/gvip
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
JWT_SECRET_KEY=change-me-in-production
STORAGE_PATH=../storage/uploads
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
